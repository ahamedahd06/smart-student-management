FLASK_ENV=development
FLASK_DEBUG=1
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=smart_student_db
JWT_SECRET=change-this-to-a-long-random-secret
JWT_EXP_HOURS=24
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Keras model exported from Colab (.keras or .h5)
EMOTION_MODEL_PATH=
# JSON mapping class index -> label, e.g. {"0":"angry","1":"happy","2":"neutral","3":"sad"}
EMOTION_LABEL_MAP_PATH=

# If 1, skip face_comparison (still runs emotion model; attributes check-in to logged-in student only)
SKIP_FACE_VERIFICATION=0
