# Optional: copy to `.env` and use python-dotenv, or set variables in PowerShell before `streamlit run`.
#
# SQLite (default: ./data/ssms.db)
# SSMS_SQLITE_PATH=C:\path\to\ssms.db
#
# Emotion ML — if unset, paths default to ../backend/models/emotion_model.keras and ../backend/ml/label_map.json when those files exist.
# SSMS_EMOTION_MODEL_PATH=
# SSMS_EMOTION_LABEL_MAP_PATH=
#
# Require @university.esu for registration (0=off)
# SSMS_REQUIRE_ESU_EMAIL=0
